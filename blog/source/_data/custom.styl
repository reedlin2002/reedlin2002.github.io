// ========================================
// custom.styl — Blog 客製化覆蓋層
// 只覆蓋需要改動的部分，其餘由主題檔負責
// ========================================

// ── 1. Anchor scroll offset (for sticky-ish header) ──
html
  scroll-padding-top: 80px

.md h1, .md h2, .md h3, .md h4
  scroll-margin-top: 80px

// ── 2. Layout: prevent horizontal scroll ──
body
  overflow-x: hidden

// ── 3. Navigation touch targets ──
// Only target nav/action links, NOT all <a> tags in prose
#nav .menu .item a,
#nav ul li a
  min-height: 44px
  padding: 0.6rem 0.875rem
  display: inline-flex
  align-items: center
  box-sizing: border-box
  transition: color 0.2s ease, background 0.2s ease

#nav ul li a:hover
  background: rgba(196, 30, 58, 0.1)
  border-radius: 4px
  color: #C41E3A

// ── 4. Button touch targets ──
button,
.btn
  min-height: 44px
  min-width: 44px
  box-sizing: border-box

// Post desktop action icons
#header-post a.icon
  min-height: 44px
  min-width: 44px
  display: inline-flex
  align-items: center
  justify-content: center
  border-radius: 6px

// Mobile nav icon sizing
@media (max-width: 900px)
  #menu-icon-tablet
    min-height: 44px
    min-width: 44px
    display: inline-flex !important
    align-items: center
    justify-content: center
    padding: 0.5rem

// ── 5. Colour / Contrast improvements ──
// Inline code (light pop against dark bg)
code:not(.highlight code)
  background: rgba(196, 30, 58, 0.10) !important
  color: #C41E3A !important
  padding: 0.15em 0.45em
  border-radius: 4px
  font-size: 0.875em
  border: 1px solid rgba(196, 30, 58, 0.2)
  font-family: 'JetBrains Mono', 'Courier New', monospace

// Meta / time contrast fix
time,
.meta time,
article time,
.post .meta time
  color: #94a3b8 !important
  font-weight: 500

.meta,
.post .meta,
article .meta
  color: #94a3b8 !important

// ── 6. Prose image improvements ──
.md img
  max-width: 100%
  height: auto
  border-radius: 8px
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.25)
  margin: 1.5rem auto
  display: block

// ── 7. Focus ring (keyboard accessibility) ──
*:focus-visible
  outline: 2px solid #C41E3A
  outline-offset: 2px
  border-radius: 3px

// ── 8. Text selection colour ──
::selection
  background: rgba(196, 30, 58, 0.3)
  color: #f1f5f9

::-moz-selection
  background: rgba(196, 30, 58, 0.3)
  color: #f1f5f9

// ── 9. Blockquote ──
blockquote
  background: rgba(30, 41, 59, 0.55) !important
  border-left: 3px solid #C41E3A !important
  border-radius: 0 8px 8px 0
  padding: 1rem 1.25rem !important
  margin: 1.5rem 0 !important
  box-shadow: none !important

// ── 10. Table improvements ──
.md table
  width: 100%
  border-collapse: collapse
  margin: 1.5rem 0
  overflow-x: auto
  display: block
  border-radius: 8px
  border: 1px solid rgba(71, 85, 105, 0.4)

.md table thead
  background: rgba(196, 30, 58, 0.12)

.md table th,
.md table td
  padding: 0.7rem 1rem
  border: 1px solid rgba(71, 85, 105, 0.3)
  text-align: left

.md table th
  font-weight: 700
  color: #e2e8f0
  border-bottom: 2px solid rgba(196, 30, 58, 0.3)

.md table tr:nth-child(even)
  background: rgba(30, 41, 59, 0.25)

// ── 11. HR ──
.md hr
  margin: 2.5rem 0
  border: none
  height: 1px
  background: linear-gradient(90deg, transparent, rgba(196, 30, 58, 0.4), transparent)

// ── 12. Post-nav (Prev / Next) ──
.post-nav
  margin: 3rem 0 2rem !important
  gap: 0.75rem

  .item a
    background-image: none !important
    border-radius: 10px !important
    padding: 1.25rem 1.5rem !important
    min-height: 5rem
    display: flex !important
    flex-direction: column !important
    justify-content: center !important
    position: relative
    text-decoration: none !important
    transition: background-color 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease !important
    box-sizing: border-box

    &::before
      display: none !important

    color: #f1f5f9 !important
    background-color: rgba(15, 23, 42, 0.85) !important
    border: 2px solid rgba(71, 85, 105, 0.5) !important
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.35) !important

    span.type
      color: #94a3b8 !important
      font-size: 0.8125rem !important
      font-weight: 700 !important
      letter-spacing: 0.06em
      text-transform: uppercase
      margin-bottom: 0.35rem

    span.category
      color: #64748b !important
      font-size: 0.8125rem !important
      margin-bottom: 0.5rem

    h3
      color: #f1f5f9 !important
      font-size: 1.0625rem !important
      font-weight: 600 !important
      margin: 0 !important
      line-height: 1.45 !important

    &:hover
      background-color: rgba(196, 30, 58, 0.12) !important
      border-color: #C41E3A !important
      color: #fff !important
      transform: translateY(-2px)
      box-shadow: 0 6px 20px rgba(196, 30, 58, 0.2) !important

      span.type,
      span.category
        color: rgba(255, 255, 255, 0.8) !important

      h3
        color: #fff !important

    &:focus-visible
      outline: 3px solid #C41E3A !important
      outline-offset: 3px !important

  .item.left a
    text-align: left
    align-items: flex-start

  .item.right a
    text-align: right
    align-items: flex-end

  @media (max-width: 767px)
    flex-direction: column

    .item
      width: 100%

      a
        padding: 1rem 1.25rem !important
        min-height: 4.5rem

// ── 13. Mobile content padding ──
@media (max-width: 767px)
  body
    font-size: 16px
    -webkit-text-size-adjust: 100%

  #main .wrap
    padding: 1rem

  pre,
  .highlight
    padding: 0.875rem
    font-size: 0.9em
    overflow-x: auto

// ── 14. Article reading width ──
#post .content
  max-width: 720px
  margin-left: auto
  margin-right: auto

// ── 15. Code block readability ──
.highlight
  border-radius: 8px !important
  overflow: hidden

.highlight pre
  line-height: 1.65

// ── 16. Search hint text ──
.search-hint
  color: #94a3b8
  font-size: 0.9rem
  margin-bottom: 1rem

// ── 17. Footer CTA button consistency ──
.footer-cta-btn
  display: inline-flex !important
  align-items: center
  gap: 6px
  padding: 0.55rem 1.1rem !important
  border-radius: 8px !important
  font-size: 0.875rem
  font-weight: 600
  text-decoration: none
  min-height: 40px
  box-sizing: border-box
  transition: transform 0.2s ease, box-shadow 0.2s ease

.footer-cta-btn:hover
  transform: translateY(-2px)

// ── 18. Responsive font & spacing micro-adjustments ──
@media (max-width: 600px)
  #hero-title
    font-size: clamp(1.4rem, 8vw, 2rem) !important
  #hero-content
    padding: 0 5vw !important

// ── 19. Card alignment consistency ──
.shoka-card-tags
  margin-bottom: 12px

.shoka-card-excerpt
  min-height: 3.4rem

// ── 20. Projects section visual distinction ──
#projects
  margin-top: 56px
  padding-top: 40px
  border-top: 1px solid rgba(212, 175, 55, 0.25)

.project-list
  list-style: none
  padding: 0
  margin-top: 24px
  display: flex
  flex-direction: column
  gap: 12px

.project-item
  padding: 14px 18px
  border-left: 3px solid rgba(212, 175, 55, 0.55)
  background: rgba(212, 175, 55, 0.04)
  border-radius: 0 8px 8px 0
  transition: border-color 0.2s ease, background 0.2s ease

.project-item:hover
  border-left-color: #D4AF37
  background: rgba(212, 175, 55, 0.09)

// ── 14. Spotify Widget (if used) ──
#spotify-widget
  position: fixed
  right: 0.75rem
  bottom: 0.75rem
  z-index: 9999
  width: 22rem
  max-width: calc(100vw - 1.5rem)
  background: rgba(255, 255, 255, 0.92)
  border-radius: 0.75rem
  box-shadow: 0 0.375rem 1.25rem rgba(0, 0, 0, 0.18)
  overflow: hidden

#spotify-widget .spotify-btn
  width: 100%
  padding: 0.6rem 0.75rem
  border: 0
  background: rgba(0, 0, 0, 0.06)
  color: inherit
  cursor: pointer

#spotify-widget #spotify-embed
  width: 100%

#spotify-widget iframe
  display: block
  width: 100%
  height: 152px
  border: 0

@media (max-width: 991px)
  #spotify-widget
    width: 18rem
